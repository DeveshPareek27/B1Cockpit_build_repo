{
  "name": "ecomm",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "CALL create_build.bat",
    "start": "electron .",
    "build-builder": "electron-builder",
    "buildDev": "electron-packager . Ecommerce-app --overwrite  --asar --platform=win32 --archx64 --prune=true  --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE  --version-string.ProductName='Ecommerce App'"
  },
  "build": {
    "appId": "com.example.Ecomm",
    "productName": "Ecommerce",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "license": "LICENSE",
      "displayLanguageSelector": true
    }
  },
  "NRelectron": {
    "productName": "ENT_B1_SysManagementTool",
    "editable": false,
    "allowLoadSave": false,
    "showMap": false,
    "kioskMode": false,
    "addNodes": true,
    "flowFile": "flow.json",
    "start": "console"
  },
  "main": "main.js",
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@juraj336/node-red-buffer-xlsx": "~1.0.1",
    "@sap-ux/ui5-middleware-fe-mockserver": "2",
    "@sap/hana-client": "2.7.23",
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^3.0.0",
    "@ui5/fs": "^2.0.6",
    "@ui5/logger": "^2.0.1",
    "electron-is-dev": "^1.2.0",
    "electron-store": "^6.0.1",
    "node-red-contrib-bcrypt": "^0.1.6",
    "ent-red-contrib-custom-logger": "file:API/ENT_RED_CustomNodes/CustomLogger",
    "express": "^4.21.2",
    "guid": "^0.0.12",
    "http-proxy-middleware": "^2.0.0",
    "mssql": "^8.1.4",
    "node-red": "^3.0.0",
    "node-red-contrib-checksum": "~1.3.0",
    "node-red-contrib-crypto-js-dynamic": "^0.1.22",
    "node-red-contrib-flogger": "~1.2.2",
    "node-red-contrib-jwt": "~0.1.0",
    "node-red-contrib-ldap-login": "file:API/ENT_RED_CustomNodes/node-red-contrib-ldap-login",
    "node-red-contrib-md5": "~1.0.4",
    "node-red-contrib-static": "~1.0.2",
    "node-red-custom-smb2": "file:API/ENT_RED_CustomNodes/node-red-custom-smb2",
    "node-red-custom-sqlite": "file:API/ENT_RED_CustomNodes/node-red-custom-sqlite",
    "node-red-custom-ssh-v3": "file:API/ENT_RED_CustomNodes/node-red-custom-ssh-v3",
    "node-red-debugger": "~1.1.1",
    "node-red-node-base64": "~0.3.0",
    "node-red-node-email": "file:API/ENT_RED_CustomNodes/node-red-node-email",
    "nodejs-winrm": "^1.1.3",
    "red-contrib-b1-gateway-config": "file:API/ENT_RED_CustomNodes/B1ApiGateway-config",
    "red-contrib-b1-gateway-request": "file:API/ENT_RED_CustomNodes/B1ApiGateway-request",
    "red-contrib-b1-service-layer-config": "file:API/ENT_RED_CustomNodes/B1ServiceLayer-config",
    "red-contrib-b1-service-layer-request": "file:API/ENT_RED_CustomNodes/B1ServiceLayer-request",
    "red-contrib-HanaClient-config": "file:API/ENT_RED_CustomNodes/HanaClient-config",
    "red-contrib-HanaClient-request": "file:API/ENT_RED_CustomNodes/HanaClient-request",
    "red-contrib-metadata-engine": "file:API/ENT_RED_CustomNodes/metadata-engine",
    "red-contrib-Odata-Converter": "file:API/ENT_RED_CustomNodes/Odata-Converter",
    "red-contrib-settings-config": "file:API/ENT_RED_CustomNodes/settings_config_node",
    "rimraf": "3.0.2",
    "sessionsecuritycheck": "file:API/ENT_RED_CustomNodes/Session-security-check",
    "ui5-middleware-index": "^0.2.6"
  },
  "devDependencies": {
    "electron": "^33.4.1",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "node-red-debugger": "^1.1.1"
  }
}
